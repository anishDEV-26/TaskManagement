@{
    ViewBag.Title = "Dashboard";
}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

<style>
    /* KEYFRAMES */
    @@keyframes fadeSlideUp {
        from { opacity: 0; transform: translateY(30px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    @@keyframes countUp {
        from { opacity: 0; transform: scale(0.6); }
        to   { opacity: 1; transform: scale(1); }
    }
    @@keyframes pulseRing {
        0%   { transform: scale(1);   opacity: 0.4; }
        70%  { transform: scale(2.2); opacity: 0; }
        100% { transform: scale(1);   opacity: 0; }
    }
    @@keyframes shimmer {
        0%   { background-position: -400px 0; }
        100% { background-position: 400px 0; }
    }
    @@keyframes floatIcon {
        0%, 100% { transform: translateY(0px); }
        50%       { transform: translateY(-6px); }
    }

    /* PAGE */
    .tm-db-page-header {
        margin-bottom: 32px;
    }
    .tm-db-page-header h2 {
        font-size: 28px;
        font-weight: 700;
        color: #1e293b;
        margin: 0 0 4px 0;
    }
    .tm-db-page-header p {
        color: #94a3b8;
        font-size: 14px;
        margin: 0;
    }

    /* GRID */
    .tm-db-main-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 28px;
    }

    /* CARD */
    .tm-db-card {
        border-radius: 24px;
        padding: 32px 28px;
        position: relative;
        overflow: hidden;
        cursor: pointer;
        opacity: 0;
        animation: fadeSlideUp 0.6s ease forwards;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .tm-db-card:hover {
        transform: translateY(-8px) scale(1.02);
        box-shadow: 0 20px 50px rgba(0,0,0,0.15);
    }

    /* STAGGERED ANIMATION DELAYS */
    .tm-db-card:nth-child(1) { animation-delay: 0.1s; }
    .tm-db-card:nth-child(2) { animation-delay: 0.2s; }
    .tm-db-card:nth-child(3) { animation-delay: 0.3s; }
    .tm-db-card:nth-child(4) { animation-delay: 0.4s; }

    /* CARD COLORS */
    .tm-db-card-orange {
        background: linear-gradient(135deg, #f97316 0%, #ea580c 100%);
        box-shadow: 0 8px 30px rgba(249,115,22,0.35);
    }
    .tm-db-card-pink {
        background: linear-gradient(135deg, #ec4899 0%, #db2777 100%);
        box-shadow: 0 8px 30px rgba(236,72,153,0.35);
    }
    .tm-db-card-green {
        background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
        box-shadow: 0 8px 30px rgba(34,197,94,0.35);
    }
    .tm-db-card-teal {
        background: linear-gradient(135deg, #14b8a6 0%, #0f766e 100%);
        box-shadow: 0 8px 30px rgba(20,184,166,0.35);
    }

    /* DECORATIVE CIRCLE BG */
    .tm-db-card::before {
        content: '';
        position: absolute;
        width: 180px;
        height: 180px;
        border-radius: 50%;
        background: rgba(255,255,255,0.08);
        top: -50px;
        right: -50px;
        pointer-events: none;
    }
    .tm-db-card::after {
        content: '';
        position: absolute;
        width: 100px;
        height: 100px;
        border-radius: 50%;
        background: rgba(255,255,255,0.06);
        bottom: -20px;
        left: 20px;
        pointer-events: none;
    }

    /* SHIMMER STRIP ON HOVER */
    .tm-db-card-shimmer {
        position: absolute;
        top: 0; left: -100%;
        width: 60%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.12), transparent);
        transition: left 0.5s ease;
        pointer-events: none;
    }
    .tm-db-card:hover .tm-db-card-shimmer {
        left: 150%;
    }

    /* ICON BOX */
    .tm-db-icon-wrap {
        position: relative;
        display: inline-flex;
        margin-bottom: 20px;
    }
    .tm-db-icon-box {
        width: 60px;
        height: 60px;
        border-radius: 16px;
        background: rgba(255,255,255,0.22);
        backdrop-filter: blur(6px);
        display: flex;
        justify-content: center;
        align-items: center;
        font-size: 26px;
        color: #fff;
        animation: floatIcon 3s ease-in-out infinite;
        position: relative;
        z-index: 1;
    }
    .tm-db-card:nth-child(2) .tm-db-icon-box { animation-delay: 0.5s; }
    .tm-db-card:nth-child(3) .tm-db-icon-box { animation-delay: 1s; }
    .tm-db-card:nth-child(4) .tm-db-icon-box { animation-delay: 1.5s; }

    /* PULSE RING */
    .tm-db-pulse-ring {
        position: absolute;
        top: 50%; left: 50%;
        transform: translate(-50%, -50%);
        width: 60px; height: 60px;
        border-radius: 16px;
        background: rgba(255,255,255,0.3);
        animation: pulseRing 2.5s ease-out infinite;
    }

    /* CARD LABEL */
    .tm-db-card-title {
        font-size: 13px;
        font-weight: 600;
        letter-spacing: 1.2px;
        text-transform: uppercase;
        color: rgba(255,255,255,0.8);
        margin-bottom: 10px;
    }

    /* CARD NUMBER */
    .tm-db-card-value {
        font-size: 52px;
        font-weight: 800;
        color: #fff;
        line-height: 1;
        animation: countUp 0.5s ease forwards;
        text-shadow: 0 2px 10px rgba(0,0,0,0.15);
    }

    /* BOTTOM BADGE */
    .tm-db-card-badge {
        margin-top: 18px;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: rgba(255,255,255,0.18);
        border-radius: 20px;
        padding: 5px 12px;
        font-size: 12px;
        color: rgba(255,255,255,0.9);
        font-weight: 500;
    }
    .tm-db-card-badge i {
        font-size: 10px;
    }

    /* RESPONSIVE */
    @@media(max-width: 900px) {
        .tm-db-main-grid { grid-template-columns: repeat(2, 1fr); gap: 18px; }
    }
    @@media(max-width: 580px) {
        .tm-db-main-grid { grid-template-columns: 1fr; }
        .tm-db-card-value { font-size: 40px; }
    }
</style>

<div class="tm-db-page-header">
    <h2><i class="fa-solid fa-chart-line" style="color:#2563eb;margin-right:10px;"></i>Dashboard Overview</h2>
    <p>Welcome back! Here's what's happening with your tasks today.</p>
</div>

<div class="tm-db-main-grid">

    <!-- TOTAL TASKS -->
    <div class="tm-db-card tm-db-card-orange">
        <div class="tm-db-card-shimmer"></div>
        <div class="tm-db-icon-wrap">
            <div class="tm-db-pulse-ring"></div>
            <div class="tm-db-icon-box">
                <i class="fa-solid fa-list-check"></i>
            </div>
        </div>
        <div class="tm-db-card-title">Total Tasks</div>
        <div class="tm-db-card-value" id="totalTasks">0</div>
        <div class="tm-db-card-badge">
            <i class="fa-solid fa-layer-group"></i> All tasks in system
        </div>
    </div>

    <!-- PENDING TASKS -->
    <div class="tm-db-card tm-db-card-pink">
        <div class="tm-db-card-shimmer"></div>
        <div class="tm-db-icon-wrap">
            <div class="tm-db-pulse-ring"></div>
            <div class="tm-db-icon-box">
                <i class="fa-solid fa-clock"></i>
            </div>
        </div>
        <div class="tm-db-card-title">Pending Tasks</div>
        <div class="tm-db-card-value" id="pendingTasks">0</div>
        <div class="tm-db-card-badge">
            <i class="fa-solid fa-hourglass-half"></i> Awaiting completion
        </div>
    </div>

    <!-- COMPLETED TASKS -->
    <div class="tm-db-card tm-db-card-green">
        <div class="tm-db-card-shimmer"></div>
        <div class="tm-db-icon-wrap">
            <div class="tm-db-pulse-ring"></div>
            <div class="tm-db-icon-box">
                <i class="fa-solid fa-circle-check"></i>
            </div>
        </div>
        <div class="tm-db-card-title">Completed Tasks</div>
        <div class="tm-db-card-value" id="completedTasks">0</div>
        <div class="tm-db-card-badge">
            <i class="fa-solid fa-check-double"></i> Successfully done
        </div>
    </div>

    <!-- OVERDUE TASKS -->
    <div class="tm-db-card tm-db-card-teal">
        <div class="tm-db-card-shimmer"></div>
        <div class="tm-db-icon-wrap">
            <div class="tm-db-pulse-ring"></div>
            <div class="tm-db-icon-box">
                <i class="fa-solid fa-triangle-exclamation"></i>
            </div>
        </div>
        <div class="tm-db-card-title">Overdue Tasks</div>
        <div class="tm-db-card-value" id="overdueTasks">0</div>
        <div class="tm-db-card-badge">
            <i class="fa-solid fa-calendar-xmark"></i> Past due date
        </div>
    </div>

</div>



<script src="/javascript/dashboard.js?v=5"></script>