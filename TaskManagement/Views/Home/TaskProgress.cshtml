@{
    ViewBag.Title = "Task Progress";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/brands.min.css" />

<style>
    .tprog-main-wrapper {
        width: 100%;
    }

    .tprog-page-title {
        font-size: 32px;
        font-weight: bold;
        margin-bottom: 30px;
        color: #1e293b;
    }

    .modal-dialog {
        max-width: 900px;
    }

    .modal-content {
        border-radius: 18px;
        border: none;
    }

    .modal-header {
        padding: 20px 30px;
        border-bottom: 1px solid #e2e8f0;
    }

    .modal-title {
        font-size: 28px;
        font-weight: bold;
    }

    .tprog-form-container {
        background: white;
        padding: 30px;
        border-radius: 18px;
    }

    .tprog-form-grid {
        display: grid;
        grid-template-columns: repeat(2,1fr);
        gap: 25px;
    }

    .tprog-input-group {
        display: flex;
        flex-direction: column;
    }

        .tprog-input-group label {
            margin-bottom: 10px;
            font-weight: 600;
            color: #334155;
            font-size: 16px;
        }

            .tprog-input-group label i {
                margin-right: 8px;
                color: #7c3aed;
            }

        .tprog-input-group select, .tprog-input-group input, .tprog-input-group textarea {
            padding: 14px;
            border: 1px solid #cbd5e1;
            border-radius: 10px;
            outline: none;
            font-size: 15px;
            transition: 0.3s;
        }

        .tprog-input-group textarea {
            resize: none;
            height: 120px;
        }

            .tprog-input-group select:focus, .tprog-input-group input:focus, .tprog-input-group textarea:focus {
                border-color: #7c3aed;
                box-shadow: 0 0 5px rgba(124,58,237,0.4);
            }

    .tprog-full-width {
        grid-column: 1 / -1;
    }

    .tprog-btn-container {
        margin-top: 30px;
        display: flex;
        gap: 15px;
    }

    .tprog-btn {
        border: none;
        padding: 13px 24px;
        border-radius: 10px;
        color: white;
        cursor: pointer;
        font-size: 15px;
        transition: 0.3s;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .tprog-btn:hover {
            transform: translateY(-2px);
        }

    .tprog-update-btn {
        position: relative;
        padding: 0.75em 1.5em;
        border-radius: 0.625em;
        border: 2px solid #4f46e5;
        font-size: 0.938em;
        text-transform: uppercase;
        font-weight: 700;
        letter-spacing: 0.125em;
        background: transparent;
        color: #4f46e5;
        overflow: hidden;
        cursor: pointer;
        box-shadow: 0 0 0 0 transparent;
        transition: all 0.3s ease-in-out;
    }

        .tprog-update-btn:hover {
            background: rgba(100, 150, 229, 0.1);
            box-shadow: 0 0 25px 5px rgba(79, 70, 229, 0.3);
            color: purple;
        }

        .tprog-update-btn::before {
            content: "";
            display: block;
            width: 0px;
            height: 86%;
            position: absolute;
            top: 7%;
            left: 0%;
            opacity: 0;
            background: linear-gradient(90deg, transparent, #4f46e5, transparent);
            box-shadow: 0 0 50px 30px #00ffff;
            transform: skewX(-20deg);
            transition: all 0.5s ease-in-out;
        }

        .tprog-update-btn:hover::before {
            animation: neon-shine 0.6s 0s infinite;
        }

    @@keyframes neon-shine {
        from {
            opacity: 0;
            left: 0%;
        }

        50% {
            opacity: 1;
        }

        to {
            opacity: 0;
            left: 100%;
        }
    }

    /* TABLE SCROLL */
    .table-responsive {
        overflow-x: auto;
    }

    /* ACTION BUTTONS ALIGNMENT */
    .action-btn-wrap {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 5px;
        flex-wrap: nowrap;
    }

    /* ACTION BUTTONS ALIGNMENT */
    .action-btn-wrap {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 5px;
        flex-wrap: nowrap;
        width: 70px;
        margin: 0 auto;
    }

    .action-btn-placeholder {
        width: 30px;
        height: 30px;
        display: inline-block;
    }

    #progressTable th:last-child,
    #progressTable td:last-child {
        min-width: 90px;
        white-space: nowrap;
    }

    @@media(max-width:900px) {
        .tprog-form-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="tprog-main-wrapper">
    <h1 class="tprog-page-title">
        <i class="fa-solid fa-chart-line"></i> Task Progress Update
    </h1>
    <button type="button" class="btn btn-primary mb-4" data-bs-toggle="modal" data-bs-target="#progressModal">
        <i class="fa-solid fa-plus"></i> Update Progress
    </button>
</div>

<!-- PROGRESS MODAL -->
<div class="modal fade" id="progressModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Task Progress Update</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="tprog-form-container">
                    <div class="tprog-form-grid">

                        <div class="tprog-input-group">
                            <label><i class="fa-solid fa-user"></i> Select Employee</label>
                            <select id="tprogEmployee">
                                <option value="">Choose Employee</option>
                            </select>
                        </div>

                        <div class="tprog-input-group">
                            <label><i class="fa-solid fa-list-check"></i> Select Task</label>
                            <select id="tprogTask">
                                <option value="">Choose Task</option>
                            </select>
                        </div>

                        <div class="tprog-input-group">
                            <label><i class="fa-solid fa-chart-simple"></i> Progress Status</label>
                            <select id="tprogStatus">
                                <option value="">Choose Status</option>
                                <option>Pending</option>
                                <option>In Progress</option>
                                <option>Completed</option>
                            </select>
                        </div>

                        <div class="tprog-input-group">
                            <label><i class="fa-solid fa-calendar-days"></i> Update Date</label>
                            <input type="date" id="tprogDate">
                        </div>

                        <div class="tprog-input-group">
                            <label><i class="fa-solid fa-calendar-check"></i> Due Date</label>
                            <input type="date" id="tprogDueDate" readonly style="background:#f1f5f9;cursor:not-allowed;">
                        </div>

                        <div class="tprog-input-group tprog-full-width">
                            <label><i class="fa-solid fa-percent"></i> Task Progress Percentage</label>
                            <select id="tprogPercentage">
                                <option>Select Progress</option>
                                <option>0%</option>
                                <option>50%</option>
                                <option>100%</option>
                            </select>
                        </div>

                        <div class="tprog-input-group tprog-full-width">
                            <label><i class="fa-solid fa-comment"></i> Remarks / Comments</label>
                            <textarea id="tprogRemarks" placeholder="Enter task progress remarks..."></textarea>
                        </div>

                    </div>
                    <div class="tprog-btn-container">
                        <button class="tprog-btn tprog-update-btn" onclick="SaveTaskProgress()">
                            <i class="fa-solid fa-pen"></i> Update Progress
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="toast-container position-fixed top-0 end-0 p-3"></div>

<!-- DELETE CONFIRM MODAL -->
<div class="modal fade" id="deleteProgressModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center">
                <i class="fa-solid fa-triangle-exclamation fa-2x text-danger mb-3"></i>
                <p>Are you sure you want to delete this progress?</p>
                <input type="hidden" id="deleteProgressId" />
            </div>
            <div class="modal-footer justify-content-center">
                <button type="button" class="btn btn-danger" onclick="ConfirmDeleteProgress()">Yes</button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">No</button>
            </div>
        </div>
    </div>
</div>

<div class="table-responsive">
    <table id="progressTable" class="table table-striped" style="width:100%">
        <thead>
            <tr>
                <th class="text-center">Sno</th>
                <th class="text-center">Employee</th>
                <th class="text-center">Task</th>
                <th class="text-center">Progress Status</th>
                <th class="text-center">Update Date</th>
                <th class="text-center">Due Date</th>
                <th class="text-center">Task Progress %</th>
                <th class="text-center">Remarks</th>
                <th class="text-center">Action</th>
            </tr>
        </thead>
        <tbody id="progressTableBody"></tbody>
    </table>
</div>

<script src="/javascript/taskprogress.js?v=3"></script>