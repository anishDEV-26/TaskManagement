@{
    ViewBag.Title = "Employees";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

<style>
    .emp-page-title {
        font-size: 32px;
        font-weight: bold;
        margin-bottom: 30px;
        color: #1e293b;
    }

    .modal-dialog {
        max-width: 900px;
    }

    .modal-content {
        border-radius: 18px;
        border: none;
    }

    .modal-header {
        padding: 20px 30px;
        border-bottom: 1px solid #e2e8f0;
    }

    .modal-title {
        font-size: 28px;
        font-weight: bold;
    }

    .emp-form-container {
        width: 100%;
        background: white;
        padding: 30px;
        border-radius: 15px;
    }

    .emp-form-grid {
        display: grid;
        grid-template-columns: repeat(2,1fr);
        gap: 25px;
    }

    .emp-input-group {
        display: flex;
        flex-direction: column;
    }

        .emp-input-group label {
            margin-bottom: 10px;
            font-weight: 600;
            color: #334155;
            font-size: 16px;
        }

            .emp-input-group label i {
                margin-right: 8px;
                color: #2563eb;
            }

        .emp-input-group input {
            padding: 14px;
            border: 1px solid #cbd5e1;
            border-radius: 10px;
            outline: none;
            font-size: 15px;
            transition: 0.3s;
        }

            .emp-input-group input:focus {
                border-color: #2563eb;
                box-shadow: 0 0 5px rgba(37,99,235,0.4);
            }

    .emp-btn-container {
        margin-top: 30px;
        display: flex;
        gap: 15px;
    }

    .emp-btn {
        border: none;
        padding: 13px 24px;
        border-radius: 10px;
        color: white;
        cursor: pointer;
        font-size: 15px;
        transition: 0.3s;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .emp-btn:hover {
            transform: translateY(-2px);
        }

    .emp-save-btn {
        position: relative;
        padding: 0.75em 1.5em;
        border-radius: 0.625em;
        border: 2px solid #4f46e5;
        font-size: 0.938em;
        text-transform: uppercase;
        font-weight: 700;
        letter-spacing: 0.125em;
        background: transparent;
        color: #4f46e5;
        overflow: hidden;
        cursor: pointer;
        box-shadow: 0 0 0 0 transparent;
        transition: all 0.3s ease-in-out;
    }

        .emp-save-btn:hover {
            background: rgba(100,150,229,0.1);
            box-shadow: 0 0 25px 5px rgba(79,70,229,0.3);
            color: purple;
        }

        .emp-save-btn::before {
            content: "";
            display: block;
            width: 0px;
            height: 86%;
            position: absolute;
            top: 7%;
            left: 0%;
            opacity: 0;
            background: linear-gradient(90deg, transparent, #4f46e5, transparent);
            box-shadow: 0 0 50px 30px #00ffff;
            transform: skewX(-20deg);
            transition: all 0.5s ease-in-out;
        }

        .emp-save-btn:hover::before {
            animation: neon-shine 0.6s 0s infinite;
        }

    @@keyframes neon-shine {
        from {
            opacity: 0;
            left: 0%;
        }

        50% {
            opacity: 1;
        }

        to {
            opacity: 0;
            left: 100%;
        }
    }

    @@media(max-width:900px) {
        .emp-form-grid {
            grid-template-columns: 1fr;
        }
    }

    /* PDF LIST MODAL */
    .pdf-list-modal .modal-dialog {
        max-width: 600px;
    }

    .pdf-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 14px 16px;
        background: #f8fafc;
        border-radius: 10px;
        margin-bottom: 10px;
        border: 1px solid #e2e8f0;
        transition: 0.2s;
    }

        .pdf-item:hover {
            background: #eff6ff;
            border-color: #bfdbfe;
        }

    .pdf-icon {
        width: 42px;
        height: 42px;
        background: #fee2e2;
        border-radius: 10px;
        display: flex;
        justify-content: center;
        align-items: center;
        flex-shrink: 0;
    }

        .pdf-icon i {
            color: #dc2626;
            font-size: 18px;
        }

    .pdf-info {
        flex: 1;
    }

    .pdf-name {
        font-size: 14px;
        font-weight: 600;
        color: #1e293b;
        margin-bottom: 3px;
        cursor: pointer;
    }

        .pdf-name:hover {
            color: #2563eb;
            text-decoration: underline;
        }

    .pdf-meta {
        font-size: 12px;
        color: #94a3b8;
    }

    .pdf-delete-btn {
        background: #fee2e2;
        border: none;
        width: 32px;
        height: 32px;
        border-radius: 8px;
        cursor: pointer;
        color: #dc2626;
        font-size: 13px;
        display: flex;
        justify-content: center;
        align-items: center;
        transition: 0.2s;
    }

        .pdf-delete-btn:hover {
            background: #dc2626;
            color: white;
        }

    .pdf-empty {
        text-align: center;
        padding: 40px;
        color: #94a3b8;
    }

        .pdf-empty i {
            font-size: 40px;
            margin-bottom: 10px;
            display: block;
        }

    .btn.btn-secondary.btn-sm {
        position: relative;
    }
</style>

<h1 class="emp-page-title">
    <i class="fa-solid fa-users"></i> Employee Management
</h1>

<button type="button" class="btn btn-primary mb-4" data-bs-toggle="modal" data-bs-target="#addEmployeeModal">
    <i class="fa-solid fa-plus"></i> Add Employee
</button>

<!-- Add Employee Modal -->
<div class="modal fade" id="addEmployeeModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Employee Management</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="emp-form-container">
                    <div class="emp-form-grid">
                        <div class="emp-input-group">
                            <label><i class="fa-solid fa-user"></i> Employee Name</label>
                            <input type="text" id="inputEmpName" placeholder="Enter Employee Name" />
                        </div>
                        <div class="emp-input-group">
                            <label><i class="fa-solid fa-envelope"></i> Email Address</label>
                            <input type="text" id="inputEmail" placeholder="Enter Email Address" />
                        </div>
                        <div class="emp-input-group">
                            <label><i class="fa-solid fa-phone"></i> Mobile Number</label>
                            <input type="text" id="inputMobile" placeholder="Enter Mobile Number" maxlength="10" />
                        </div>
                        <div class="emp-input-group">
                            <label><i class="fa-solid fa-briefcase"></i> Role</label>
                            <input type="text" id="inputRole" placeholder="Enter Role" />
                        </div>
                    </div>
                    <div class="emp-btn-container">
                        <button class="emp-btn emp-save-btn" onclick="SaveEmployee()">
                            <i class="fa-solid fa-floppy-disk"></i> Save
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Edit Employee Modal -->
<div class="modal fade" id="editEmployeeModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit Employee</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="emp-form-container">
                    <input type="hidden" id="editEmpId" />
                    <div class="emp-form-grid">
                        <div class="emp-input-group">
                            <label><i class="fa-solid fa-user"></i> Employee Name</label>
                            <input type="text" id="editEmpName" />
                        </div>
                        <div class="emp-input-group">
                            <label><i class="fa-solid fa-envelope"></i> Email Address</label>
                            <input type="text" id="editEmail" />
                        </div>
                        <div class="emp-input-group">
                            <label><i class="fa-solid fa-phone"></i> Mobile Number</label>
                            <input type="text" id="editMobile" />
                        </div>
                        <div class="emp-input-group">
                            <label><i class="fa-solid fa-briefcase"></i> Role</label>
                            <input type="text" id="editRole" />
                        </div>
                    </div>
                    <div class="emp-btn-container">
                        <button class="emp-btn emp-save-btn" onclick="UpdateEmployee()">
                            <i class="fa-solid fa-floppy-disk"></i> Update
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Delete Employee Modal -->
<div class="modal fade" id="deleteEmployeeModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center">
                <i class="fa-solid fa-triangle-exclamation fa-2x text-danger mb-3"></i>
                <p>Are you sure you want to delete this employee?</p>
                <input type="hidden" id="deleteEmpId" />
            </div>
            <div class="modal-footer justify-content-center">
                <button type="button" class="btn btn-danger" onclick="ConfirmDeleteEmployee()">Yes</button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">No</button>
            </div>
        </div>
    </div>
</div>

<!-- PDF List Modal -->
<div class="modal fade pdf-list-modal" id="pdfListModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fa-solid fa-file-pdf" style="color:#dc2626;margin-right:8px;"></i>
                    Imported Files — <span id="pdfModalEmpName"></span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="pdfListContainer"></div>
            </div>
        </div>
    </div>
</div>

<!-- Hidden file input -->
<input type="file" id="hiddenFileInput" accept=".pdf" multiple style="display:none;" onchange="UploadPdf()" />

<div class="toast-container position-fixed top-0 end-0 p-3"></div>

<table id="employeeTable" class="table table-striped" style="width:100%">
    <thead>
        <tr>
            <th class="text-center">Sno</th>
            <th class="text-center">Employee Name</th>
            <th class="text-center">Email Address</th>
            <th class="text-center">Mobile Number</th>
            <th class="text-center">Role</th>
            <th class="text-center">Action</th>
        </tr>
    </thead>
    <tbody id="employeeTableBody"></tbody>
</table>

<script src="/javascript/employee.js?v=2"></script>